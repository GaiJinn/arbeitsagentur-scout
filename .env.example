# Copy to .env and fill in.

# Groq API key — sign up free at https://console.groq.com
GROQ_API_KEY=gsk_xxx

# Telegram bot token from @BotFather on Telegram
TELEGRAM_TOKEN=1234567890:abcdefghijklmnopqrstuvwxyz

# Your personal chat ID — see README for how to find it
TELEGRAM_CHAT_ID=123456789

# Minimum LLM score (1-10) to trigger a Telegram alert. Default 6.
SCORE_THRESHOLD=6

# Minimum LLM score to also offer a "generate tailored CV" button.
# Requires BASE_CV_PATH and telegram_bot.py running. Default 7.
CV_SCORE_THRESHOLD=7

# Path to your base CV (PDF) — used by telegram_bot.py to generate tailored
# CVs. Mounted into the container by docker-compose.
BASE_CV_PATH=/app/cv.pdf

# Where to put the SQLite db. Default works inside Docker.
DB_PATH=/data/jobs.db

# Dead-man's switch: on a run with nothing above threshold, send a short
# "scout läuft" heartbeat at most once per this many hours, so silence means
# "no new jobs" and not "cron/container/token is dead". 0 disables. Default 24.
HEARTBEAT_HOURS=24

# Safety valve on Groq usage: max LLM scoring calls per run. Jobs beyond the
# cap are deferred to a later run instead of blowing the free-tier quota in
# one broad/first run. 0 = no cap. Default 50.
MAX_LLM_CALLS_PER_RUN=50

# Optional external uptime monitor (e.g. https://healthchecks.io). Create a
# free check (period ~4h, generous grace), then paste its ping URL here. scout
# pings it on a clean run and <url>/fail on a crash; the monitor alerts you if
# the ping ever stops (cron dead, VPS down, import error). Empty = disabled.
HEALTHCHECK_URL=

LOG_LEVEL=INFO
